{
  "hosting": [
    {
      "target": "user",
      "public": "dist",
      "ignore": [
        "admin.html",
        "assets/admin-*.js",
        "assets/admin-*.css",
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "admin",
      "public": "dist",
      "ignore": [
        "index.html",
        "assets/index-*.js",
        "assets/index-*.css",
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/admin.html"
        }
      ]
    }
  ]
}
