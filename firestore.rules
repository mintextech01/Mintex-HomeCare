rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Contact form submissions:
    // - Anyone can write (unauthenticated users submitting the contact form)
    // - Only authenticated admin can read
    match /appData/submissions {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // All other app data (services, testimonials, team, gallery, jobs, contactInfo, siteImages):
    // - Anyone can read (user panel displays this data publicly)
    // - Only authenticated admin can write
    match /appData/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
