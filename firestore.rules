rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Submissions collection: one document per submission (contact or career).
    // - Anyone can create (unauthenticated users submitting forms)
    // - Only authenticated admin can read, update, or delete
    match /submissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
      // public create allowed for contact/career forms
    }

    // Legacy single-document submissions (kept for backward compat — no longer written to)
    match /appData/submissions {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // All other app data (services, testimonials, team, gallery, jobs, contactInfo):
    // - Anyone can read (user panel displays this data publicly)
    // - Only authenticated admin can write
    match /appData/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Site images stored per-key to avoid the 1MB single-document limit.
    // Each document: siteImageData/{imageKey} → { url: "..." }
    match /siteImageData/{imageKey} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
